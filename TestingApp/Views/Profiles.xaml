<UserControl x:Class="FileSorter.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Content area -->
            <RowDefinition Height="*" />
            <!-- Button at bottom -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Back" Command="{Binding GoBackCommand}" Margin="10" Height="40" Width="300" FontWeight="Bold"/>
            <Button Grid.Column="1" Content="Add rule" Command="{Binding AddRuleCommand}" Margin="10" Height="40" Width="300" FontWeight="Bold"/>

        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding Rules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5">
                                <StackPanel>

                                    <TextBlock Text="Target folder:" />

                                    <TextBox Text="{Binding TargetFolder}" />

                                    <TextBlock Text="Extensions:" />

                                    <ItemsControl ItemsSource="{Binding Extensions}">

                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="Gray" BorderThickness="1" Margin="2">
                                                    <StackPanel Orientation="Horizontal" Margin="2">
                                                        <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                                        <Button Content="✕" FontWeight="Bold" Width="20" Height="20" Foreground="Red" BorderBrush="Transparent" Background="Transparent" Command="{Binding DataContext.RemoveExtensionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                    <Button Margin="5"  Content="Add Extension" Command="{Binding DataContext.AddExtensionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                                    <Button Margin="5" Content="Remove rule" Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
        
        <!--Saving and exporting-->
        <Grid Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Save rules" Command="{Binding SaveRulesCommand}" Margin="5" Height="20" Width="150" FontWeight="Bold"/>
            <Button Grid.Column="1" Content="Import rules" Command="{Binding ImportCommand}" Margin="5" Height="20" Width="150" FontWeight="Bold"/>
            <Button Grid.Column="2" Content="Export rules" Command="{Binding ExportCommand}" Margin="5" Height="20" Width="150" FontWeight="Bold"/>
        </Grid>
    </Grid>
</UserControl>
